{
  "rules": {
    "catalog": {
      ".read": true,
      ".write": false
    },
    "books": {
      ".read": true,
      ".write": false
    },
    "book-files": {
      ".read": "auth != null",
      ".write": false
    },
    "orders": {
      ".read": true,
      "$orderId": {
        ".write": "!data.exists() && newData.hasChildren(['phone','items','status']) && newData.child('status').val() === 'pending'",
        ".validate": "newData.hasChildren(['phone','items','status','createdAt'])"
      }
    },
    "promoCodes": {
      ".read": true,
      ".write": "auth != null"
    },
    "pending_orders": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "admin": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
