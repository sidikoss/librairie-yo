{
  "rules": {
    ".read": false,
    ".write": false,
    
    "catalog": {
      ".read": true,
      ".write": false,
      ".indexOn": ["category"]
    },
    
    "books": {
      ".read": true,
      ".write": false
    },
    
    "book-files": {
      ".read": "auth != null && auth.uid === data.child('allowedUid').val()",
      ".write": false
    },
    
    // PROBLEME 3 FIX: Orders can only be read by admin on client-side
    // Normal users will use the secure /api/user-orders endpoint
    "orders": {
      ".read": "auth != null && auth.token.admin === true",
      ".indexOn": ["phone", "status", "createdAt"],
      "$orderId": {
        // Orders are created server-side via Orange Money verification API
        ".write": "auth != null && auth.token.admin === true",
        // Validate required fields
        ".validate": "newData.hasChildren(['phone','items','status','createdAt','total'])"
      }
    },
    
    // Payment references storage (server-side only)
    "usedPaymentRefs": {
      ".read": false, // Not exposed to clients
      ".write": "auth != null && auth.token.admin === true" // Admin only
    },
    
    "promoCodes": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true",
      "$promoId": {
        ".validate": "newData.hasChildren(['code','discount']) || newData.child('.value').val() === null"
      }
    },
    
    "pending_orders": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true"
    },
    
    "admin": {
      ".read": "auth != null && auth.token.admin === true",
      ".write": "auth != null && auth.token.admin === true"
    },
    
    // Cache for catalog (read-only for all)
    "cache": {
      ".read": true,
      ".write": "auth != null && auth.token.admin === true"
    },
    
    // User sessions
    "sessions": {
      "$sessionId": {
        ".read": "data.child('uid').val() === auth.uid",
        ".write": "!data.exists() && newData.hasChildren(['uid','createdAt'])",
        ".validate": "newData.child('uid').val() === auth.uid"
      }
    }
  }
}