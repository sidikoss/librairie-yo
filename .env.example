# Admin password — server-side only (used by /api/admin-auth)
# ⚠️ Do NOT prefix with VITE_ — that would expose it in the client bundle!
ADMIN_PASSWORD=your_secure_password_here

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# Public app URL (server-side, used by api/*). Do NOT prefix with VITE_.
APP_PUBLIC_URL=https://librairie-yo.vercel.app

# Claude (Anthropic) — server-side only (used by /api/claude)
CLAUDE_API_KEY=
# Optional: override model used by the proxy
# CLAUDE_MODEL=claude-3-5-sonnet-latest
# Optional: allow CORS from a single origin (leave empty for same-origin)
# CLAUDE_CORS_ORIGIN=https://your-domain.example
# Optional: increase/decrease calls per minute per IP
# CLAUDE_RATE_LIMIT_MAX=30
# Optional: Anthropics API version header
# CLAUDE_ANTHROPIC_VERSION=2023-06-01

FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_DATABASE_URL=
FIREBASE_STORAGE_BUCKET=

# Optional JSON full service account
# FIREBASE_SERVICE_ACCOUNT_JSON=

# Reader options
# READER_ORDER_SOURCE=auto
# READER_RATE_LIMIT_MAX=80
# READER_ORDERS_COLLECTION=orders
# READER_BOOK_FILES_COLLECTION=bookFiles
